APP_NAME="Tipsy API"
ENVIRONMENT="development"
DATABASE_URL="sqlite:///./tipsy.db"

HARDWARE_MODE="raspberrypi"

GPIO_NUMBERING_MODE="BCM"
GPIO_ACTIVE_LOW="false"
GPIO_CLEANUP_ON_SHUTDOWN="true"
GPIO_POLL_INTERVAL_SECONDS="0.05"

PUMP_PIN_MAP="1=17/4,2=9/10,3=5/11,4=13/6,5=26/19,6=20/21,7=16/12,8=24/25"
