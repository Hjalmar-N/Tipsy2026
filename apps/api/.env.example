APP_NAME="Tipsy API"
ENVIRONMENT="development"
DATABASE_URL="sqlite:///./tipsy.db"

# Hardware selection
HARDWARE_MODE="mock"

# Raspberry Pi GPIO settings
GPIO_NUMBERING_MODE="BCM"
GPIO_ACTIVE_LOW="false"
GPIO_CLEANUP_ON_SHUTDOWN="true"
GPIO_POLL_INTERVAL_SECONDS="0.05"

# Optional pump pin overrides.
# Format: pump_id=pin,pump_id=pin
# Example: 1=17,2=27,3=22
PUMP_PIN_MAP=""
